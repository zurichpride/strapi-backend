{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "he/him",
        "she/her",
        "they/them"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Geschäftsstelle",
        "Vorstand",
        "Organisationskomitee"
      ]
    },
    "team": {
      "type": "enumeration",
      "enum": [
        "Digital",
        "Administration",
        "Festival",
        "Partners",
        "Sicherheit",
        "Politik",
        "Finanzen",
        "Kommunikation"
      ]
    },
    "function": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "links": {
      "type": "component",
      "component": "elements.links",
      "repeatable": false
    }
  }
}
